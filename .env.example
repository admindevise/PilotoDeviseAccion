# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fideicomiso_platform?schema=public"

# Anthropic AI
ANTHROPIC_API_KEY="sk-ant-..."

# App
NODE_ENV="development"
API_PORT=4000
WEB_PORT=3000
PORT=3000
DEBUG="true"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_URL_INTERNAL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-in-production"
AUTH_TRUST_HOST="true"

# Frontend -> API
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"

# Storage (S3-compatible)
S3_BUCKET="fideicomiso-docs"
S3_REGION="us-east-1"
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# Redis (for queues)
REDIS_URL="redis://localhost:6379"

# Despliegue en Railway
RAILWAY_API_DEPLOY_HOOK_URL="https://railway.app/api/webhooks/deploy/..."
RAILWAY_WEB_DEPLOY_HOOK_URL="https://railway.app/api/webhooks/deploy/..."
