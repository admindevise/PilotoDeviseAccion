{
  "name": "fideicomiso-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma de Conciliación Integral de Fideicomisos - MVP",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:migrate": "pnpm --filter @fideicomiso/api exec prisma migrate dev",
    "db:push": "pnpm --filter @fideicomiso/api exec prisma db push",
    "db:seed": "pnpm --filter @fideicomiso/api exec prisma db seed",
    "db:reset-hallazgos": "pnpm --filter @fideicomiso/api exec ts-node prisma/reset_hallazgos.ts",
    "db:generate": "pnpm --filter @fideicomiso/api exec prisma generate",
    "db:studio": "pnpm --filter @fideicomiso/api exec prisma studio"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "eslint": "^10.0.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.10",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}
